# Sample environment configuration for Nebius / Nemotron integration.
#
# Copy this file to `.env` (which should be git-ignored) and fill in real values.
#
# IMPORTANT:
# - Do NOT commit your real tokens or secrets.
# - Use Nebius Token Factory to issue short-lived tokens where possible.

# Set to 1, true, or yes to use the LLM for exploration parameters; omit or set to 0 to use keyword mapping only.
# Use this to compare behavior with LLM on vs off.
USE_LLM=0

# Set to 1 to print why the LLM path failed (no api_key, API error, parse error) or the parsed params on success.
# DEBUG_LLM=1

# Full HTTPS URL for the Nemotron-3-Super-120b-a12b chat/completions endpoint.
# Example (adjust to your actual Nebius endpoint shape):
# NEBIUS_LLM_ENDPOINT="https://llm-api.nebius.cloud/v1/chat/completions"
NEBIUS_LLM_ENDPOINT=""

# API key for the OpenAI-compatible client (adhoc.py and llm_client.py).
# The client uses NEBIUS_API_KEY if set, otherwise OPENAI_API_KEY.
# Get this from Nebius Token Factory and put it in .env (do not commit).
# NEBIUS_API_KEY="your-token-factory-api-key"
# OPENAI_API_KEY="your-token-factory-api-key"
NEBIUS_API_KEY=""

